cd# ──────────────────────────────────────────────────────────────
# Datumart Next.js Frontend – Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google Maps API Key (for Place ID Finder embed, optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Default Place ID for demo (use Google Place ID Finder to get yours)
NEXT_PUBLIC_DEFAULT_PLACE_ID=ChIJ0X31pIK3woAR5KwBnToO6S0
